{
  "expo": {
    "name": "EmoCare",
    "slug": "emocare-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0720"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow EmoCare to understand your voice so Emo can respond.",
        "NSMicrophoneUsageDescription": "Allow EmoCare to listen during Voice Talk."
      },
      "bundleIdentifier": "com.tristarinter.emocare"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A0F2E"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.tristarinter.emocare"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#070312",
      "name": "EmoCare — Your Sanctuary",
      "shortName": "EmoCare",
      "description": "A private sanctuary for check-ins, journal, and conversations with Emo.",
      "themeColor": "#0D0720",
      "display": "standalone",
      "startUrl": "/",
      "scope": "/",
      "orientation": "portrait",
      "lang": "en"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#0D0720"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow EmoCare to access your photos so you can share them with Emo."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow EmoCare to listen during Voice Talk — your conversations stay private on this device."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow EmoCare to listen during Voice Talk.",
          "speechRecognitionPermission": "Allow EmoCare to understand your voice so Emo can respond."
        }
      ],
      "expo-asset"
    ]
  }
}
