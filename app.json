{
  "expo": {
    "name": "EmoCare AI",
    "slug": "emocare-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A0F2E"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow EmoCare to understand your voice so Emo can respond.",
        "NSMicrophoneUsageDescription": "Allow EmoCare to listen during Voice Talk."
      },
      "bundleIdentifier": "com.anonymous.emocareai"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.anonymous.emocareai"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A0F2E",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow EmoCare to access your photos so you can share them with Emo."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow EmoCare to listen during Voice Talk — your acoustic sanctuary stays private on this device."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow EmoCare to listen during Voice Talk.",
          "speechRecognitionPermission": "Allow EmoCare to understand your voice so Emo can respond."
        }
      ],
      "expo-asset"
    ]
  }
}
