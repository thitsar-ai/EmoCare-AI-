{
  "expo": {
    "name": "EmoCare",
    "slug": "emocare-ai",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4ECFB"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Allow EmoCare to unlock your sanctuary with Face ID."
      },
      "bundleIdentifier": "com.tristarinter.emocare"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4ECFB"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.tristarinter.emocare"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#F4ECFB",
      "name": "EmoCare — Your Sanctuary",
      "shortName": "EmoCare",
      "description": "A private sanctuary for check-ins, journal, and conversations with Emo.",
      "themeColor": "#F4ECFB",
      "display": "standalone",
      "startUrl": "/",
      "scope": "/",
      "orientation": "portrait",
      "lang": "en"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#F4ECFB"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow EmoCare to access your photos so you can share them with Emo."
        }
      ],
      "expo-asset",
      "expo-secure-store",
      "expo-local-authentication"
    ]
  }
}
